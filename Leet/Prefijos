/**
 * @param {string[]} strs
 * @return {string}
 */
var longestCommonPrefix = function (strs) {
  if (strs.length == 0 || strs[0] == '') return '';
  if (strs.length == 1) return strs[0];
  let ans = '';
  let i = 0;
  while (true) {
    for (j = 1; j < strs.length; j++) {
      if (strs[j][i] != strs[0][i] || strs[j][i] == undefined) return ans;
    }
    ans += strs[0][i];
    i++;
  }
};

